$ rule split_sentences
    (
        - sentence $( $sent )+ . $( $rest )+
    )
    (
        statement $( $sent )+
        sentence $( $rest )+
    )
$ rule split_sentences
    (
        - sentence $( $words )+ .
    )
    (
        statement $( $words )+
    )

