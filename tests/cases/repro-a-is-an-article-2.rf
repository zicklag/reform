$ rule x_is_y
    (
        - sentence $( $a1 )? $x is $( $a2 )? $y
        $( $a1 is article )?
        $( $a2 is article )?
    )
    (
        $x is $y
    )

an is article

# Regression: this was not working, but would work if we
# defined `dummy is an article` above.
an a is an article

$ assert an is article
$ assert a is article
